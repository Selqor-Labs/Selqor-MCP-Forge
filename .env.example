# Dashboard authentication module
# Dashboard auth is placeholder-only by default.
DASHBOARD_AUTH_PROVIDER=placeholder

# Dashboard secret encryption key (Fernet, 32-byte url-safe base64).
# Used to encrypt stored API keys, tokens, and passwords at rest.
# If unset, a key is auto-generated into <state_dir>/.forge-secret.key on first
# run and a warning is printed. Setting it here makes the key survive state-dir
# rebuilds and fresh clones.
#
# Generate with:
#     python scripts/init_secret_key.py         # writes into ./.env for you
# or manually:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# WARNING: Losing this value makes previously-stored secrets unreadable.
FORGE_SECRET_KEY=

# PostgreSQL metadata storage
# Leave blank to use the embedded local SQLite database in the dashboard state dir.
POSTGRES_USER=example_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=selqor_forge
POSTGRES_PORT=5432
DATABASE_URL=
POSTGRES_SEEDS=

# MinIO / S3-compatible artifact storage
# Leave blank to store artifacts on the local filesystem.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_REGION=us-east-1
MINIO_PREFIX=selqor-forge

# Optional LLM provider credentials
ANTHROPIC_API_KEY=

# Optional generated-server auth helpers
FORGE_STATIC_HEADERS_JSON={}
FORGE_TOKEN_HEADER=Authorization
FORGE_TOKEN_PREFIX=Bearer
